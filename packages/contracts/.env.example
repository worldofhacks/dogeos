# DogeOS Aggregation Router — deployment config
# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER put a private key in this file or any committed file. See the key section below.

# --- The two addresses (public, safe to keep here) ---

# ROUTER_SAFE: your Gnosis Safe (the address you control). In the deploy script this becomes the
# TimelockController's proposer/executor; the router's owner is the deployed Timelock, so all
# fee/cap/guardian/unpause changes flow through the Safe + timelock delay.
ROUTER_SAFE=0xYourGnosisSafeAddress

# ROUTER_GUARDIAN: a separate hot-key address that can ONLY pause() (fast incident response).
# It cannot unpause or change fees/caps. Can be a plain EOA you control.
ROUTER_GUARDIAN=0xYourGuardianAddress

# TimelockController minimum delay, in seconds (172800 = 48h).
TIMELOCK_MIN_DELAY=172800

# --- The deployer key (SECRET — do NOT store the raw key here) ---
# Recommended: import it once into Foundry's ENCRYPTED keystore, then deploy with --account:
#   cast wallet import dogeos-deployer --interactive      # paste key once, set a password
#   forge script ... --account dogeos-deployer --sender <DEPLOYER_ADDRESS>
# Only the PUBLIC deployer address is referenced here (for --sender):
DEPLOYER_ADDRESS=0xYourDeployerAddress

# Fund the deployer with testnet DOGE first: https://faucet.testnet.dogeos.com
