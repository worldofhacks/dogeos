# DogeSwap — server / runtime configuration. Copy to `.env` (gitignored) and fill in.

# --- DogeOS SDK Connect Kit (wallets: MyDoge + WalletConnect) ---
# Required for the in-app DogeOS Connect Kit modal and mobile MyDoge (WalletConnect).
# You get this AFTER hosting the app at a public domain and registering it at
# https://sdk.dogeos.com/register . DOGEOS_CLIENT_ID is read at SERVER RUNTIME (via
# /runtime-config.js) — set it and restart, NO rebuild needed. (VITE_* is baked at build time.)
DOGEOS_CLIENT_ID=
VITE_DOGEOS_CLIENT_ID=

# Optional: WalletConnect Cloud project id (enables WalletConnect / mobile wallets).
WALLETCONNECT_PROJECT_ID=
VITE_WALLETCONNECT_PROJECT_ID=

# --- Server binding (for hosting) ---
# Bind to 0.0.0.0 so the server is reachable on the host; put it behind nginx/Caddy for the domain + TLS.
HOST=0.0.0.0
PORT=8080
